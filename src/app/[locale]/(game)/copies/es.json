  "story": {
    "tent": {
      "title": "Una tierra nueva",
      "body": "Llegas sin nada salvo el peso que dejaste atrás. Plantas una sola tienda bajo el cielo abierto. Lo que venga, lo construirás tú mismo."
    },
    "campfire": {
      "title": "El primer fuego",
      "body": "Prendes una llama y la oscuridad retrocede. Atraída por el calor, una anciana aparece al borde de la luz, y se sienta."
    },
    "house": {
      "title": "Cuatro paredes",
      "body": "Viga a viga, una casa toma forma. Por primera vez en mucho tiempo, hay una puerta que es tuya para abrir — y para cerrar."
    },
    "grove": {
      "title": "Raíces",
      "body": "Plantas los primeros brotes en tierra cansada. Una viajera se detiene, sorprendida: 'Aquí ahora crecen cosas', dice, y decide quedarse."
    },
    "workshop": {
      "title": "Chispas",
      "body": "La fragua brilla. El herrero dispone sus herramientas. 'Tráeme lo que encuentres ahí fuera', dice, 'y haré que valga algo'."
    },
    "stable": {
      "title": "Caminos abiertos",
      "body": "Resuenan cascos por el campamento. La tierra ya es lo bastante ancha para recorrerla — y hay horizontes que merecen alcanzarse."
    },
    "gardens": {
      "title": "Vuelve el color",
      "body": "Donde había suelo desnudo, se abren flores. El campamento huele a algo que no es ceniza. La gente afloja el paso para respirarlo."
    },
    "fountain": {
      "title": "Un latido",
      "body": "Brota agua limpia de la piedra y se remansa en el centro del campamento. El lugar por fin tiene corazón, y late."
    },
    "library": {
      "title": "Palabras antiguas",
      "body": "Se alzan estanterías y se llenan. El bibliotecario llega con historias más viejas que esta tierra. 'Todo lugar merece una memoria', dice."
    },
    "gym": {
      "title": "A propósito",
      "body": "Un lugar hecho para fortalecerse por elección, no por accidente. El entrenador cruje los nudillos. 'Bien', asiente. 'Ahora trabajamos'."
    },
    "statues": {
      "title": "Recordado",
      "body": "Se alzan figuras de piedra que marcan en quién te has convertido. Los viajeros pasarán y se preguntarán quién construyó todo esto. Tú — un día tras otro."
    },
    "market": {
      "title": "Un pueblo, por fin",
      "body": "Comerciantes llenan la plaza; el cocinero enciende los fogones. Lo que empezó como una tienda ya es un pueblo. Nada fue suerte. Fuiste tú, cada día."
    }
  },
