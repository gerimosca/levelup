  "story": {
    "tent": {
      "title": "A new land",
      "body": "You arrive with nothing but the weight you left behind. You pitch a single tent under an open sky. Whatever comes next, you'll build it yourself."
    },
    "campfire": {
      "title": "The first fire",
      "body": "You strike a flame and the dark steps back. Drawn by the warmth, an old woman appears at the edge of the light, and sits."
    },
    "house": {
      "title": "Four walls",
      "body": "Beam by beam, a house takes shape. For the first time in a long time, there's a door that's yours to open — and to close."
    },
    "grove": {
      "title": "Roots",
      "body": "You plant the first saplings in tired soil. A passing wanderer stops, surprised: 'Things grow here now,' she says, and decides to stay."
    },
    "workshop": {
      "title": "Sparks",
      "body": "The forge glows. The blacksmith lays out his tools. 'Bring me what you find out there,' he says, 'and I'll make it worth something.'"
    },
    "stable": {
      "title": "Open roads",
      "body": "Hoofbeats echo through the camp. The land is wide enough to roam now — and there are horizons worth reaching."
    },
    "gardens": {
      "title": "Color returns",
      "body": "Where there was bare ground, flowers open. The camp smells of something other than ash. People slow down to breathe it in."
    },
    "fountain": {
      "title": "A heartbeat",
      "body": "Clean water springs from the stone and pools at the center of camp. The place finally has a heart, and it's beating."
    },
    "library": {
      "title": "Old words",
      "body": "Shelves rise and fill. The librarian arrives carrying stories older than this land. 'Every place deserves a memory,' he says."
    },
    "gym": {
      "title": "On purpose",
      "body": "A place built to grow stronger by choice, not by accident. The trainer cracks his knuckles. 'Alright,' he nods. 'Now we work.'"
    },
    "statues": {
      "title": "Remembered",
      "body": "Stone figures rise to mark who you've become. Travelers will pass and wonder who built all this. You did — one day at a time."
    },
    "market": {
      "title": "A town, at last",
      "body": "Traders fill the square; the cook fires up the stove. What began as one tent is a town now. None of it was luck. It was you, every day."
    }
  },
